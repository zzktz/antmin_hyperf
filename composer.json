{
    "name": "zzktz/antmin-hyperf",
    "description": "Antmin admin package for Hyperf 3.1.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0.1",
        "hyperf/cache": "~3.1.0",
        "hyperf/command": "~3.1.0",
        "hyperf/config": "~3.1.0",
        "hyperf/context": "~3.1.0",
        "hyperf/contract": "~3.1.0",
        "hyperf/database": "~3.1.0",
        "hyperf/db-connection": "~3.1.0",
        "hyperf/di": "~3.1.0",
        "hyperf/filesystem": "~3.1.0",
        "hyperf/framework": "~3.1.0",
        "hyperf/guzzle": "~3.1.0",
        "hyperf/http-message": "~3.1.0",
        "hyperf/http-server": "~3.1.0",
        "hyperf/logger": "~3.1.0",
        "hyperf/model-cache": "~3.1.0",
        "hyperf/redis": "~3.1.0",
        "hyperf/validation": "~3.1.0",
        "lcobucci/jwt": "^5.4",
        "league/flysystem": "^3.0",
        "league/flysystem-local": "^3.0",
        "php-amqplib/php-amqplib": "^3.0",
        "psr/container": "^1.1 || ^2.0",
        "psr/http-message": "^1.0 || ^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "hyperf/testing": "~3.1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Antmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AntminTest\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-autoload-dump": [
            "rm -rf runtime/container"
        ],
        "test": "phpunit --colors=always"
    },
    "extra": {
        "hyperf": {
            "config": "Antmin\\ConfigProvider"
        }
    }
}
